 check_workspace      # Verify that libraries in your workspace are correct
   [-allow_missing]       (Missing cells/arcs/checks in the base lib are added)
   [-noresolve]           (Don't resolve fixable problems)
   [-output_ems_database ems_database_name]
                          (File name of the output EMS database)
   [-details detail_list] (Show various verbose details: 
                           Values: all, arcs_progress, 
                           breakpoint_comparisons, ccsn, cell_em, 
                           combine_physical, dynamic_power, 
                           leakage_progress, physical_only_cells, 
                           receiver_caps, scaling_group_info, 
                           step_by_step)

