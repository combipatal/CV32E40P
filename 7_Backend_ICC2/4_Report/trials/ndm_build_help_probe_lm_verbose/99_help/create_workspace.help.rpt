 create_workspace     # Create the workspace in which your library will be built
   [-technology tech_file]
                          (Technology file name)
   [-flow flow_type]      (Create a library with specified flow: 
                           Values: aggregate, edit, etm_moded, 
                           exploration, frame, normal, physical_only, 
                           verification)
   [-scale_factor precision]
                          (Internal length precision)
   [-use_technology_lib tech_lib_name]
                          (Technology library name)
   library_spec           (Name for the library, or library to edit)

